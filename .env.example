## Backend (Express on Vercel Serverless)

# Mongo
MONGODB_URI=
MONGO_DB_NAME=skillmatchai

# AI
GEMINI_API_KEY=

# Firebase Admin (optional, for protected routes + realtime notifications)
# Recommended on Vercel: paste the full service account JSON (or base64-encoded JSON) here.
FIREBASE_SERVICE_ACCOUNT_JSON=
# Alternatively (if you prefer splitting fields):
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# Optional (will be derived from project id if omitted)
FIREBASE_DATABASE_URL=

# CORS (comma-separated). Example: https://your-frontend.vercel.app,http://localhost:3000
CORS_ORIGIN=

# Local dev only
PORT=5000
