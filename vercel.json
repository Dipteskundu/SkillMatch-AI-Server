{
  "version": 2,
  "routes": [{ "src": "/(.*)", "dest": "/api/index.js" }]
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": {
        "maxLambdaSize": "50mb",
        "maxDuration": 30,
        "includeFiles": "**"
      }
    }
  ],
  "rewrites": [{ "source": "/(.*)", "destination": "/api/index.js" }]
}
